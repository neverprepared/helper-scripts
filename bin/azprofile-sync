#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

CHECK="✓"
CROSS="✗"
ARROW="→"
SYNC="⟳"

AZPROFILE_HOME="${AZPROFILE_HOME:-$HOME}"

usage() {
    echo -e "${BOLD}${BLUE}azprofile-sync${NC} — Sync Azure profiles to/from a remote directory"
    echo
    echo -e "  ${BOLD}Usage:${NC}"
    echo -e "    azprofile-sync push <target-dir> [profile]"
    echo -e "    azprofile-sync pull <source-dir> [profile]"
    echo
    echo -e "  ${BOLD}Examples:${NC}"
    echo -e "    azprofile-sync push /Volumes/backup          ${DIM}# Push active profile${NC}"
    echo -e "    azprofile-sync push /Volumes/backup work     ${DIM}# Push 'work' profile${NC}"
    echo -e "    azprofile-sync pull /Volumes/backup work     ${DIM}# Pull 'work' profile${NC}"
    echo
    echo -e "  ${BOLD}Environment:${NC}"
    echo -e "    AZPROFILE_HOME    Base directory (default: \$HOME)"
    echo -e "    AZPROFILE_SYNC    Default sync directory (used if <dir> is omitted)"
}

die() { echo -e "${RED}${CROSS} $1${NC}" >&2; exit 1; }

get_current() {
    local link="$AZPROFILE_HOME/.azure"
    if [ -L "$link" ]; then
        basename "$(readlink "$link")"
    else
        echo ""
    fi
}

do_sync() {
    local src="$1"
    local dst="$2"
    local label="$3"

    echo
    echo -e "${BOLD}${BLUE}${SYNC} Azure Profile Sync${NC}"
    echo -e "${DIM}─────────────────────${NC}"
    echo -e "${CYAN}${ARROW}${NC} ${label}"
    echo -e "${CYAN}${ARROW}${NC} Source: ${DIM}${src}${NC}"
    echo -e "${CYAN}${ARROW}${NC} Target: ${DIM}${dst}${NC}"
    echo

    mkdir -p "$dst"

    if rsync -av "$src" "$dst" 2>&1 | while read -r line; do
        if [[ "$line" == *"sending"* ]] || [[ "$line" == *"sent"* ]] || [[ "$line" == *"total"* ]]; then
            echo -e "  ${DIM}${line}${NC}"
        elif [[ -n "$line" ]]; then
            echo -e "  ${GREEN}${CHECK}${NC} ${line}"
        fi
    done; then
        echo
        echo -e "${GREEN}${CHECK} Sync complete${NC}"
    else
        echo
        echo -e "${RED}${CROSS} Sync failed${NC}"
        exit 1
    fi
}

# Parse arguments
ACTION="${1:-}"
[ -n "$ACTION" ] || { usage; exit 1; }

REMOTE_DIR="${2:-${AZPROFILE_SYNC:-}}"
[ -n "$REMOTE_DIR" ] || die "No sync directory specified. Pass a directory or set AZPROFILE_SYNC."

PROFILE="${3:-}"

# Resolve profile name and paths
if [ -n "$PROFILE" ]; then
    LOCAL_DIR="$AZPROFILE_HOME/.azure-profiles/$PROFILE/"
    REMOTE_PROFILE_DIR="$REMOTE_DIR/.azure-profiles/$PROFILE/"
else
    PROFILE="$(get_current)"
    if [ -n "$PROFILE" ] && [ -d "$AZPROFILE_HOME/.azure-profiles/$PROFILE" ]; then
        LOCAL_DIR="$AZPROFILE_HOME/.azure-profiles/$PROFILE/"
        REMOTE_PROFILE_DIR="$REMOTE_DIR/.azure-profiles/$PROFILE/"
    else
        # Fall back to plain .azure directory
        LOCAL_DIR="$AZPROFILE_HOME/.azure/"
        REMOTE_PROFILE_DIR="$REMOTE_DIR/.azure/"
        PROFILE="(default)"
    fi
fi

case "$ACTION" in
    push)
        [ -d "$LOCAL_DIR" ] || die "Local profile directory not found: $LOCAL_DIR"
        do_sync "$LOCAL_DIR" "$REMOTE_PROFILE_DIR" "Pushing profile '${PROFILE}'"
        ;;
    pull)
        [ -d "$REMOTE_PROFILE_DIR" ] || die "Remote profile directory not found: $REMOTE_PROFILE_DIR"
        do_sync "$REMOTE_PROFILE_DIR" "$LOCAL_DIR" "Pulling profile '${PROFILE}'"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        die "Unknown action: $ACTION. Use 'push' or 'pull'."
        ;;
esac
