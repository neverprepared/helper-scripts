#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

CHECK="✓"
CROSS="✗"
ARROW="→"

AZPROFILE_HOME="${AZPROFILE_HOME:-$HOME}"
PROFILES_DIR="$AZPROFILE_HOME/.azure-profiles"
ACTIVE_LINK="$AZPROFILE_HOME/.azure"

die() { echo -e "${RED}${CROSS} $1${NC}" >&2; exit 1; }

# Ensure profiles directory exists
ensure_profiles_dir() {
    mkdir -p "$PROFILES_DIR"
}

# Migrate existing .azure directory to a profile if needed
migrate_if_needed() {
    if [ -d "$ACTIVE_LINK" ] && [ ! -L "$ACTIVE_LINK" ]; then
        ensure_profiles_dir
        local target="$PROFILES_DIR/default"
        if [ -d "$target" ]; then
            die "Cannot migrate: $target already exists"
        fi
        echo -e "${YELLOW}${ARROW}${NC} Migrating existing .azure/ to profile 'default'..."
        mv "$ACTIVE_LINK" "$target"
        ln -s "$target" "$ACTIVE_LINK"
        echo -e "${GREEN}${CHECK}${NC} Migrated. Active profile is now 'default'."
        echo
    fi
}

# Get the currently active profile name
get_current() {
    if [ -L "$ACTIVE_LINK" ]; then
        basename "$(readlink "$ACTIVE_LINK")"
    elif [ -d "$ACTIVE_LINK" ]; then
        echo "(unmigrated directory)"
    else
        echo "(none)"
    fi
}

cmd_current() {
    echo -e "${BOLD}${BLUE}Active profile:${NC} $(get_current)"
}

cmd_list() {
    ensure_profiles_dir
    local current
    current="$(get_current)"

    echo -e "${BOLD}${BLUE}Azure Profiles${NC}"
    echo -e "${DIM}──────────────${NC}"

    local found=0
    for dir in "$PROFILES_DIR"/*/; do
        [ -d "$dir" ] || continue
        found=1
        local name
        name="$(basename "$dir")"
        if [ "$name" = "$current" ]; then
            echo -e "  ${GREEN}${CHECK}${NC} ${BOLD}${name}${NC} ${DIM}(active)${NC}"
        else
            echo -e "  ${DIM}-${NC} ${name}"
        fi
    done

    if [ "$found" -eq 0 ]; then
        echo -e "  ${DIM}No profiles. Run: azprofile init <name>${NC}"
    fi
}

cmd_use() {
    local name="${1:-}"
    [ -n "$name" ] || die "Usage: azprofile use <name>"

    migrate_if_needed

    local target="$PROFILES_DIR/$name"
    [ -d "$target" ] || die "Profile '$name' not found. Run: azprofile init $name"

    # Remove existing symlink (or fail if it's somehow a real dir after migration)
    if [ -L "$ACTIVE_LINK" ]; then
        rm "$ACTIVE_LINK"
    elif [ -e "$ACTIVE_LINK" ]; then
        die "$ACTIVE_LINK exists and is not a symlink. Run azprofile again to migrate."
    fi

    ln -s "$target" "$ACTIVE_LINK"
    echo -e "${GREEN}${CHECK}${NC} Switched to ${BOLD}${name}${NC}"

    # Show account info
    if command -v az &>/dev/null; then
        local acct
        acct="$(az account show --query '{user:user.name, subscription:name, tenant:tenantId}' -o tsv 2>/dev/null)" || true
        if [ -n "$acct" ]; then
            echo -e "${DIM}  $(echo "$acct" | awk '{print $1}')${NC}"
        fi
    fi
}

cmd_init() {
    local name="${1:-}"
    [ -n "$name" ] || die "Usage: azprofile init <name>"

    migrate_if_needed
    ensure_profiles_dir

    local target="$PROFILES_DIR/$name"
    mkdir -p "$target"

    echo -e "${BOLD}${BLUE}Initializing profile '${name}'${NC}"
    echo -e "${CYAN}${ARROW}${NC} Config dir: ${DIM}${target}${NC}"
    echo

    # Run az login into the profile directory
    AZURE_CONFIG_DIR="$target" az login

    echo
    echo -e "${GREEN}${CHECK}${NC} Profile '${name}' initialized."
    echo -e "${DIM}  Switch to it with: azprofile use ${name}${NC}"
}

cmd_whoami() {
    if ! command -v az &>/dev/null; then
        die "az CLI not found"
    fi

    local current
    current="$(get_current)"
    echo -e "${BOLD}${BLUE}Profile:${NC} ${current}"
    echo -e "${DIM}──────────────${NC}"
    az account show -o table
}

CRON_TAG_PREFIX="# azprofile-refresh"
REFRESH_SCRIPT="$(cd "$(dirname "$0")" && pwd)/azprofile-refresh"

cron_tag_for() {
    local profile="${1:-all}"
    echo "${CRON_TAG_PREFIX}:${profile}"
}

cmd_cron() {
    local action="${1:-status}"

    case "$action" in
        install)
            local profile="${2:-}"
            local schedule="${3:-13 * * * *}"
            local tag
            tag="$(cron_tag_for "$profile")"

            local refresh_args=""
            local label="all profiles"
            if [ -n "$profile" ]; then
                [ -d "$PROFILES_DIR/$profile" ] || die "Profile '$profile' not found. Run: azprofile init $profile"
                refresh_args=" $profile"
                label="profile '$profile'"
            fi

            local cron_line="AZPROFILE_HOME=$AZPROFILE_HOME ${schedule} ${REFRESH_SCRIPT}${refresh_args} >> ${AZPROFILE_HOME}/.azure-profiles/refresh.log 2>&1 ${tag}"

            # Remove existing entry for this specific profile/all, then append
            local existing
            existing="$(crontab -l 2>/dev/null || true)"
            local filtered
            filtered="$(echo "$existing" | grep -v "$tag" || true)"

            if [ -n "$filtered" ]; then
                printf '%s\n%s\n' "$filtered" "$cron_line" | crontab -
            else
                echo "$cron_line" | crontab -
            fi

            echo -e "${GREEN}${CHECK}${NC} Cron installed for ${BOLD}${label}${NC}: ${DIM}${schedule}${NC}"
            echo -e "${DIM}  Log: ${AZPROFILE_HOME}/.azure-profiles/refresh.log${NC}"
            ;;
        remove)
            local profile="${2:-}"
            local tag

            if [ -n "$profile" ]; then
                tag="$(cron_tag_for "$profile")"
            else
                # No profile specified: remove all azprofile-refresh entries
                tag="$CRON_TAG_PREFIX"
            fi

            local existing
            existing="$(crontab -l 2>/dev/null || true)"
            local filtered
            filtered="$(echo "$existing" | grep -v "$tag" || true)"

            if [ -z "$filtered" ]; then
                crontab -r 2>/dev/null || true
            else
                echo "$filtered" | crontab -
            fi

            if [ -n "$profile" ]; then
                echo -e "${GREEN}${CHECK}${NC} Cron removed for profile '${profile}'"
            else
                echo -e "${GREEN}${CHECK}${NC} All azprofile crons removed"
            fi
            ;;
        status)
            local entries
            entries="$(crontab -l 2>/dev/null | grep "$CRON_TAG_PREFIX" || true)"
            if [ -n "$entries" ]; then
                echo -e "${GREEN}${CHECK}${NC} Installed crons:"
                while IFS= read -r line; do
                    echo -e "  ${DIM}${line}${NC}"
                done <<< "$entries"
            else
                echo -e "${DIM}-${NC} No crons installed. Run: azprofile cron install [profile] [schedule]"
            fi
            ;;
        *)
            die "Usage: azprofile cron [install [profile] [schedule]|remove [profile]|status]"
            ;;
    esac
}

cmd_help() {
    echo -e "${BOLD}${BLUE}azprofile${NC} — Azure multi-identity manager"
    echo
    echo -e "  ${BOLD}list${NC}            Show all profiles"
    echo -e "  ${BOLD}use <name>${NC}      Switch to a profile"
    echo -e "  ${BOLD}current${NC}         Show active profile"
    echo -e "  ${BOLD}init <name>${NC}     Create a profile and login"
    echo -e "  ${BOLD}whoami${NC}          Show active account details"
    echo -e "  ${BOLD}cron install [profile] [schedule]${NC}"
    echo -e "                    Install token refresh cron (all profiles or specific one)"
    echo -e "  ${BOLD}cron remove [profile]${NC}"
    echo -e "                    Remove cron (specific profile, or all if omitted)"
    echo -e "  ${BOLD}cron status${NC}     Show installed crons"
    echo -e "  ${BOLD}help${NC}            Show this help"
}

case "${1:-help}" in
    list)    cmd_list ;;
    use)     cmd_use "${2:-}" ;;
    current) cmd_current ;;
    init)    cmd_init "${2:-}" ;;
    whoami)  cmd_whoami ;;
    cron)    cmd_cron "${2:-}" "${3:-}" "${4:-}" ;;
    help|-h|--help) cmd_help ;;
    *)       die "Unknown command: $1. Run: azprofile help" ;;
esac
